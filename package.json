{
  "name": "dashboard",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@11.4.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "fpatino": "ng serve --host 0.0.0.0 --port 4500 --open --configuration fpatino",
    "dev": "ng serve --open",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "preview": "serve dist/dashboard/browser",
    "analyze": "ng build --configuration production --stats-json && npx esbuild-visualizer dist/dashboard/stats.json --open",
    "test": "ng test",
    "test:ci": "vitest run --coverage",
    "lint:fix": "npm run lint:accessibility:fix",
    "lint:accessibility": "eslint \"src/**/*.{ts,html}\" --config eslint.config.js",
    "lint:accessibility:fix": "eslint \"src/**/*.{ts,html}\" --config eslint.config.js --fix",
    "lint:accessibility:json": "node -e \"require('fs').mkdirSync('reports',{recursive:true})\" && eslint \"src/**/*.{ts,html}\" --config eslint.config.js --format json --output-file reports/eslint-accessibility.json",
    "lint:accessibility:report": "node scripts/eslint-a11y-report.js",
    "lint:accessibility:all": "npm run lint:accessibility && npm run lint:accessibility:report",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint:accessibility && npm run build",
    "check:fix": "npm run format && npm run lint:accessibility:fix && npm run build",
    "prepare": "husky",
    "commit": "git-cz"
  },
  "dependencies": {
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/platform-browser": "21.2.7",
    "@angular/router": "21.2.7",
    "@jsverse/transloco": "^8.2.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.7",
    "@angular/platform-browser-dynamic": "21.2.7",
    "@axe-core/playwright": "^4.10.2",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^4.1.0",
    "angular-eslint": "21.3.0",
    "concurrently": "^9.2.1",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "html-validate": "^10.1.2",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.3.3",
    "playwright": "^1.55.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "sass": "^1.98.0",
    "serve": "^14.2.6",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,html,css,scss,js,json,md}": [
      "prettier --write"
    ],
    "*.ts": [
      "eslint --fix"
    ]
  }
}
