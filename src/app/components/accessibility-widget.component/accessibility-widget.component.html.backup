<div class="accessibility-widget">
  <!-- Botón flotante de accesibilidad -->
  <button
    class="accessibility-toggle"
    (click)="togglePanel()"
    aria-label="Ajustes de accesibilidad"
    [attr.aria-expanded]="isOpen() ? 'true' : 'false'"
    [attr.aria-controls]="isOpen() ? 'accessibility-panel' : null"
  >
    <svg
      class="accessibility-icon"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
      <path
        d="M12 2C13.1 2 14 2.9 14 4C14 5.1 13.1 6 12 6C10.9 6 10 5.1 10 4C10 2.9 10.9 2 12 2Z"
        fill="currentColor"
      />
      <path
        d="M12 18C13.1 18 14 18.9 14 20C14 21.1 13.1 22 12 22C10.9 22 10 21.1 10 20C10 18.9 10.9 18 12 18Z"
        fill="currentColor"
      />
      <path
        d="M4 12C4 13.1 4.9 14 6 14C7.1 14 8 13.1 8 12C8 10.9 7.1 10 6 10C4.9 10 4 10.9 4 12Z"
        fill="currentColor"
      />
      <path
        d="M16 12C16 13.1 16.9 14 18 14C19.1 14 20 13.1 20 12C20 10.9 19.1 10 18 10C16.9 10 16 10.9 16 12Z"
        fill="currentColor"
      />
    </svg>
    <span class="accessibility-text">Accesibilidad</span>
  </button>

  <!-- Panel emergente de ajustes -->
  @if (isOpen()) {
    <div
      id="accessibility-panel"
      class="accessibility-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="accessibility-title"
    >
      <div class="panel-header">
        <h3 id="accessibility-title">Ajustes de Accesibilidad</h3>
        <button class="close-button" (click)="closePanel()" aria-label="Cerrar panel de accesibilidad">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <div class="panel-content">
        <!-- Tamaño de texto -->
        <div class="setting-group">
          <div class="setting-label">Tamaño del texto</div>
          <div class="size-controls">
            <button
              class="size-btn"
              (click)="decreaseFontSize()"
              aria-label="Reducir tamaño del texto"
              [disabled]="currentFontSizePercentage() <= 80"
            >
              <span>A-</span>
            </button>
            <span class="size-indicator">{{ currentFontSizePercentage() }}%</span>
            <button
              class="size-btn"
              (click)="increaseFontSize()"
              aria-label="Aumentar tamaño del texto"
              [disabled]="currentFontSizePercentage() >= 150"
            >
              <span>A+</span>
            </button>
          </div>
        </div>

        <!-- Contraste -->
        <div class="setting-group">
          <div class="setting-label">Modo de contraste</div>
          <div class="contrast-info">
            @if (isDarkMode()) {
              <small class="theme-info">Tema oscuro activado en el sistema</small>
            }
          </div>
          <div class="contrast-options" role="radiogroup" aria-labelledby="contrast-label">
            <button
              class="contrast-btn"
              role="radio"
              (click)="setContrastMode('normal')"
              [class.active]="contrastMode() === 'normal'"
              [attr.aria-checked]="contrastMode() === 'normal' ? 'true' : 'false'"
              aria-label="Modo de contraste normal"
            >
              Normal
            </button>
            <button
              class="contrast-btn"
              role="radio"
              (click)="setContrastMode('high')"
              [class.active]="contrastMode() === 'high'"
              [attr.aria-checked]="contrastMode() === 'high' ? 'true' : 'false'"
              aria-label="Modo de alto contraste"
            >
              Alto contraste
            </button>
            <button
              class="contrast-btn"
              role="radio"
              (click)="setContrastMode('dark')"
              [class.active]="contrastMode() === 'dark'"
              [attr.aria-checked]="contrastMode() === 'dark' ? 'true' : 'false'"
              aria-label="Modo oscuro accesible"
            >
              Oscuro
            </button>
          </div>

          <!-- Opciones adicionales de alto contraste WCAG -->
          <div class="setting-group">
            <div class="setting-label">Alto contraste WCAG</div>
            <div class="contrast-options" role="radiogroup" aria-labelledby="contrast-wcag-label">
              <button
                class="contrast-btn"
                role="radio"
                (click)="setContrastMode('white-blue')"
                [class.active]="contrastMode() === 'white-blue'"
                [attr.aria-checked]="contrastMode() === 'white-blue' ? 'true' : 'false'"
                aria-label="Blanco sobre azul"
              >
                Blanco/Azul
              </button>
              <button
                class="contrast-btn"
                role="radio"
                (click)="setContrastMode('blue-white')"
                [class.active]="contrastMode() === 'blue-white'"
                [attr.aria-checked]="contrastMode() === 'blue-white' ? 'true' : 'false'"
                aria-label="Azul sobre blanco"
              >
                Azul/Blanco
              </button>
              <button
                class="contrast-btn"
                role="radio"
                (click)="setContrastMode('green-black')"
                [class.active]="contrastMode() === 'green-black'"
                [attr.aria-checked]="contrastMode() === 'green-black' ? 'true' : 'false'"
                aria-label="Verde sobre negro"
              >
                Verde/Negro
              </button>
              <button
                class="contrast-btn"
                role="radio"
                (click)="setContrastMode('black-green')"
                [class.active]="contrastMode() === 'black-green'"
                [attr.aria-checked]="contrastMode() === 'black-green' ? 'true' : 'false'"
                aria-label="Negro sobre verde"
              >
                Negro/Verde
              </button>
            </div>

            <!-- Más opciones de contraste -->
            <div class="setting-group">
              <div class="setting-label">Más contraste</div>
              <div class="contrast-options" role="radiogroup" aria-labelledby="more-contrast-label">
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('black-cyan')"
                  [class.active]="contrastMode() === 'black-cyan'"
                  [attr.aria-checked]="contrastMode() === 'black-cyan' ? 'true' : 'false'"
                  aria-label="Negro sobre cian"
                >
                  Negro/Cian
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('cyan-black')"
                  [class.active]="contrastMode() === 'cyan-black'"
                  [attr.aria-checked]="contrastMode() === 'cyan-black' ? 'true' : 'false'"
                  aria-label="Cian sobre negro"
                >
                  Cian/Negro
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('purple-white')"
                  [class.active]="contrastMode() === 'purple-white'"
                  [attr.aria-checked]="contrastMode() === 'purple-white' ? 'true' : 'false'"
                  aria-label="Púrpura sobre blanco"
                >
                  Púrpura/Blanco
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('white-purple')"
                  [class.active]="contrastMode() === 'white-purple'"
                  [attr.aria-checked]="contrastMode() === 'white-purple' ? 'true' : 'false'"
                  aria-label="Blanco sobre púrpura"
                >
                  Blanco/Púrpura
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('orange-black')"
                  [class.active]="contrastMode() === 'orange-black'"
                  [attr.aria-checked]="contrastMode() === 'orange-black' ? 'true' : 'false'"
                  aria-label="Naranja sobre negro"
                >
                  Naranja/Negro
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('black-orange')"
                  [class.active]="contrastMode() === 'black-orange'"
                  [attr.aria-checked]="contrastMode() === 'black-orange' ? 'true' : 'false'"
                  aria-label="Negro sobre naranja"
                >
                  Negro/Naranja
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('magenta-black')"
                  [class.active]="contrastMode() === 'magenta-black'"
                  [attr.aria-checked]="contrastMode() === 'magenta-black' ? 'true' : 'false'"
                  aria-label="Magenta sobre negro"
                >
                  Magenta/Negro
                </button>
                <button
                  class="contrast-btn"
                  role="radio"
                  (click)="setContrastMode('black-magenta')"
                  [class.active]="contrastMode() === 'black-magenta'"
                  [attr.aria-checked]="contrastMode() === 'black-magenta' ? 'true' : 'false'"
                  aria-label="Negro sobre magenta"
                >
                  Negro/Magenta
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Espaciado de línea -->
        <div class="setting-group">
          <div class="setting-label">Espaciado de línea</div>
          <div class="spacing-controls" role="radiogroup" aria-labelledby="spacing-label">
            <button
              class="spacing-btn"
              role="radio"
              (click)="setLineSpacing('normal')"
              [class.active]="lineSpacing() === 'normal'"
              [attr.aria-checked]="lineSpacing() === 'normal' ? 'true' : 'false'"
              aria-label="Espaciado de línea normal"
            >
              Normal
            </button>
            <button
              class="spacing-btn"
              role="radio"
              (click)="setLineSpacing('wide')"
              [class.active]="lineSpacing() === 'wide'"
              [attr.aria-checked]="lineSpacing() === 'wide' ? 'true' : 'false'"
              aria-label="Espaciado de línea amplio"
            >
              Amplio
            </button>
            <button
              class="spacing-btn"
              role="radio"
              (click)="setLineSpacing('extra-wide')"
              [class.active]="lineSpacing() === 'extra-wide'"
              [attr.aria-checked]="lineSpacing() === 'extra-wide' ? 'true' : 'false'"
              aria-label="Espaciado de línea muy amplio"
            >
              Muy amplio
            </button>
          </div>
        </div>

        <!-- Foco visible -->
        <div class="setting-group">
          <div class="setting-label">Indicadores de foco</div>
          <div class="focus-toggle">
            <label class="toggle-switch">
              <input
                type="checkbox"
                [checked]="highContrastFocus()"
                (change)="toggleHighContrastFocus()"
                aria-describedby="focus-description"
              />
              <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">Foco de alto contraste</span>
            <span id="focus-description" class="setting-description">
              Aumenta la visibilidad de los elementos enfocados
            </span>
          </div>
        </div>

        <!-- Enlaces subrayados -->
        <div class="setting-group">
          <div class="setting-label">Estilo de enlaces</div>
          <div class="focus-toggle">
            <label class="toggle-switch">
              <input
                type="checkbox"
                [checked]="shouldUnderlineLinks()"
                (change)="toggleUnderlineLinks()"
                aria-describedby="underline-description"
              />
              <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">Subrayar enlaces permanentemente</span>
            <span id="underline-description" class="setting-description">
              Mantiene los enlaces subrayados siempre visibles
            </span>
          </div>
        </div>

        <!-- Reducción de animaciones -->
        <div class="setting-group">
          <div class="setting-label">Animaciones</div>
          <div class="focus-toggle">
            <label class="toggle-switch">
              <input
                type="checkbox"
                [checked]="shouldReduceAnimations()"
                (change)="toggleReduceAnimations()"
                aria-describedby="animation-description"
              />
              <span class="toggle-slider"></span>
            </label>
            <span class="toggle-label">Reducir animaciones</span>
            <span id="animation-description" class="setting-description">
              Minimiza movimientos para usuarios sensibles
            </span>
          </div>
        </div>

        <!-- Reset -->
        <div class="setting-actions">
          <button
            class="reset-btn"
            (click)="resetSettings()"
            aria-label="Restablecer todos los ajustes de accesibilidad a valores predeterminados"
          >
            Restablecer ajustes
          </button>
        </div>

        <!-- Información adicional -->
        <div class="setting-info">
          <p class="info-text">
            <strong>Tip:</strong>
            Estos ajustes se guardan automáticamente y se aplicarán en tu próxima visita.
          </p>
          <p class="info-text">
            <strong>Atajo:</strong>
            Presiona
            <kbd>Escape</kbd>
            para cerrar este panel.
          </p>
        </div>
      </div>
    </div>

    <!-- Botón de navegación de documentación -->
    <button
      class="documentation-toggle"
      (click)="toggleDocumentationNav()"
      [attr.aria-expanded]="showDocumentationNav()"
      aria-label="Abrir navegación de documentación"
    >
      <span class="documentation-toggle__icon">📚</span>
      <span class="documentation-toggle__text">Docs</span>
    </button>

      }
</div>
